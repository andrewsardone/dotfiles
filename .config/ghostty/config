# Font
font-family = JetBrains Mono
font-family-bold = JetBrains Mono Bold
font-family-italic = JetBrains Mono Italic
font-family-bold-italic = JetBrains Mono Bold Italic
font-size = 13
adjust-cell-height = 5%

# Window
macos-titlebar-style = tabs
window-padding-x = 8
window-padding-y = 0

# Bell
bell-features = no-system,no-audio,no-attention,no-title,no-border

# Shell integration
shell-integration = detect

# Keybindings
keybind = ctrl+shift+e=new_window

# Colors — Nightfox (aps mod)
background = 111111
foreground = cdcecf
selection-background = 2b3b51
selection-foreground = cdcecf

# Cursor
cursor-color = cdcecf

# Split border — no direct equivalent found, removed

# Normal colors
palette = 0=#393b44
palette = 1=#c94f6d
palette = 2=#81b29a
palette = 3=#dbc074
palette = 4=#719cd6
palette = 5=#9d79d6
palette = 6=#63cdcf
palette = 7=#dfdfe0

# Bright colors
palette = 8=#575860
palette = 9=#d16983
palette = 10=#8ebaa4
palette = 11=#e0c989
palette = 12=#86abdc
palette = 13=#baa1e2
palette = 14=#7ad5d6
palette = 15=#e4e4e5

# Extended colors
palette = 16=#f4a261
